# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: alternate API key for load balancing
# ANTHROPIC_API_KEY_ALT=sk-ant-...

# Default model for agent and token counting (optional)
# DEFAULT_MODEL=claude-opus-4-6

# Transcripts directory (optional, defaults to ./transcripts)
# TRANSCRIPTS_DIR=./transcripts

# Server settings
# HOST=127.0.0.1
# PORT=8000

# CORS origins (comma-separated, optional — defaults to localhost dev ports)
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173
